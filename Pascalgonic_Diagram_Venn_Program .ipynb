import numpy as np


def zero_mask(M, tol=1e-12):
    """
    Return a boolean mask indicating which entries are treated as zero.
    """
    return np.abs(M) <= tol


def maximum_bipartite_matching_zero(Z):
    """
    Find a maximum matching on the zero-pattern matrix Z
    using DFS-based augmenting paths.

    Parameters
    ----------
    Z : np.ndarray of bool, shape (n, n)
        True means the entry is zero and can be matched.

    Returns
    -------
    row_to_col : list[int]
        row_to_col[r] = matched column of row r, or -1 if unmatched
    col_to_row : list[int]
        col_to_row[c] = matched row of column c, or -1 if unmatched
    match_size : int
        Number of matched pairs
    """
    n = Z.shape[0]
    row_to_col = [-1] * n
    col_to_row = [-1] * n

    def dfs(r, seen_cols):
        for c in range(n):
            if Z[r, c] and not seen_cols[c]:
                seen_cols[c] = True
                if col_to_row[c] == -1 or dfs(col_to_row[c], seen_cols):
                    row_to_col[r] = c
                    col_to_row[c] = r
                    return True
        return False

    for r in range(n):
        seen_cols = [False] * n
        dfs(r, seen_cols)

    match_size = sum(x != -1 for x in row_to_col)
    return row_to_col, col_to_row, match_size


def minimum_vertex_cover_from_matching(Z, row_to_col, col_to_row):
    """
    Construct a minimum vertex cover from a maximum matching
    in a bipartite graph represented by zero mask Z.

    Parameters
    ----------
    Z : np.ndarray of bool, shape (n, n)
    row_to_col : list[int]
    col_to_row : list[int]

    Returns
    -------
    cover_rows : list[int]
    cover_cols : list[int]
    """
    n = Z.shape[0]
    unmatched_rows = [r for r in range(n) if row_to_col[r] == -1]

    visited_rows = [False] * n
    visited_cols = [False] * n
    stack = unmatched_rows[:]

    for r in unmatched_rows:
        visited_rows[r] = True

    while stack:
        r = stack.pop()
        for c in range(n):
            if Z[r, c]:
                if row_to_col[r] != c and not visited_cols[c]:
                    visited_cols[c] = True
                    rr = col_to_row[c]
                    if rr != -1 and not visited_rows[rr]:
                        visited_rows[rr] = True
                        stack.append(rr)

    cover_rows = [r for r in range(n) if not visited_rows[r]]
    cover_cols = [c for c in range(n) if visited_cols[c]]
    return cover_rows, cover_cols


def apply_cover_update(M, cover_rows, cover_cols):
    """
    Hungarian matrix update step:
    - subtract the minimum uncovered value from all uncovered entries
    - add it to entries covered twice
    """
    n = M.shape[0]
    cover_rows_set = set(cover_rows)
    cover_cols_set = set(cover_cols)

    uncovered = [
        M[i, j]
        for i in range(n)
        for j in range(n)
        if i not in cover_rows_set and j not in cover_cols_set
    ]

    if not uncovered:
        return M.copy(), 0.0

    delta = min(uncovered)
    newM = M.copy()

    for i in range(n):
        for j in range(n):
            row_cov = i in cover_rows_set
            col_cov = j in cover_cols_set

            if not row_cov and not col_cov:
                newM[i, j] -= delta
            elif row_cov and col_cov:
                newM[i, j] += delta

    return newM, delta


def hungarian_with_steps(cost_matrix):
    """
    Hungarian algorithm with stored intermediate steps.

    Parameters
    ----------
    cost_matrix : array-like, shape (n, n)

    Returns
    -------
    assignment : dict
        assignment[row] = column
    steps : list[dict]
        detailed intermediate steps
    """
    C = np.array(cost_matrix, dtype=float)
    n = C.shape[0]
    steps = []

    steps.append({
        "name": "Initial cost matrix",
        "matrix": C.copy()
    })

    # Step 1: Row reduction
    row_mins = C.min(axis=1)
    C = C - row_mins[:, None]
    steps.append({
        "name": "After row reduction",
        "matrix": C.copy(),
        "row_mins": row_mins.copy()
    })

    # Step 2: Column reduction
    col_mins = C.min(axis=0)
    C = C - col_mins[None, :]
    steps.append({
        "name": "After column reduction",
        "matrix": C.copy(),
        "col_mins": col_mins.copy()
    })

    iteration = 0
    while True:
        # Step 3: Find zero pattern and maximum matching
        Z = zero_mask(C)
        row_to_col, col_to_row, match_size = maximum_bipartite_matching_zero(Z)

        steps.append({
            "name": f"Zero matching check {iteration}",
            "matrix": C.copy(),
            "zero_mask": Z.copy(),
            "row_to_col": row_to_col[:],
            "match_size": match_size,
        })

        # If perfect matching exists, finish
        if match_size == n:
            assignment = {r: row_to_col[r] for r in range(n)}
            steps.append({
                "name": "Final independent zeros / optimal assignment",
                "matrix": C.copy(),
                "assignment": assignment.copy(),
            })
            return assignment, steps

        # Step 4: Minimum vertex cover
        cover_rows, cover_cols = minimum_vertex_cover_from_matching(
            Z, row_to_col, col_to_row
        )

        # Step 5: Update matrix
        updated_C, delta = apply_cover_update(C, cover_rows, cover_cols)

        steps.append({
            "name": f"Cover/update iteration {iteration}",
            "matrix_before": C.copy(),
            "cover_rows": cover_rows[:],
            "cover_cols": cover_cols[:],
            "delta": delta,
            "matrix_after": updated_C.copy(),
        })

        C = updated_C
        iteration += 1


def solve_square_assignment(cost_matrix, collect_steps=False):
    """
    Solve a square assignment problem using the Hungarian algorithm.

    Parameters
    ----------
    cost_matrix : array-like, shape (n, n)
    collect_steps : bool

    Returns
    -------
    assignment : dict
        assignment[row] = column
    steps : list or None
    objective : float
        objective value computed on the ORIGINAL cost matrix
    """
    C = np.array(cost_matrix, dtype=float)
    n = C.shape[0]

    if n == 0:
        return {}, ([] if collect_steps else None), 0.0

    assignment, steps = hungarian_with_steps(C)
    objective = sum(C[r, c] for r, c in assignment.items())

    return assignment, (steps if collect_steps else None), objective
